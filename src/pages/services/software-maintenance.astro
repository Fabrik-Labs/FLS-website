            </div>
            <div class="flex items-start gap-3">
              <span class="text-teal mt-1 flex-shrink-0">&#10003;</span>
              <p class="font-sans text-16px text-charcoal leading-relaxed">Regular uptime and performance reporting</p>
            </div>
