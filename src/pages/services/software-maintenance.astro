        <!-- Security & Updates -->
        <div class="mb-16 max-w-800px">
          <h3 class="font-sans text-20px font-semibold text-charcoal mb-6">Security & Updates</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex items-start gap-3">
              <span class="text-teal mt-1 flex-shrink-0">&#10003;</span>
              <p class="font-sans text-16px text-charcoal leading-relaxed">Dependency and library updates</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-teal mt-1 flex-shrink-0">&#10003;</span>
              <p class="font-sans text-16px text-charcoal leading-relaxed">Security patch management</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-teal mt-1 flex-shrink-0">&#10003;</span>
